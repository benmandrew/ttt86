#!/usr/bin/expect -f

set timeout 1
source ./tests/util.exp

spawn_binary

send "3"
send "1"
send "5"
send "2"
send "7"

expect_exact "в”Ңв”Җв”¬в”Җв”¬в”Җв”җ"
expect_exact "в”ӮOв”ӮOв”ӮXв”Ӯ"
expect_exact "в”ңв”Җв”јв”Җв”јв”Җв”Ө"
expect_exact "в”Ӯ в”ӮXв”Ӯ в”Ӯ"
expect_exact "в”ңв”Җв”јв”Җв”јв”Җв”Ө"
expect_exact "в”ӮXв”Ӯ в”Ӯ в”Ӯ"
expect_exact "в””в”Җв”ҙв”Җв”ҙв”Җв”ҳ"
expect_exact "The winner is: X"
